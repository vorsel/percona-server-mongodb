envAwsChecksums = env.Clone()
envAwsChecksums.Append(
    CPPPATH=[
        "dist/crt/aws-crt-cpp/crt/aws-c-common/include",
        "dist/crt/aws-crt-cpp/crt/aws-checksums/include"
    ],
    CPPDEFINES=[
        "AWS_CHECKSUMS_EXPORTS",
        "AWS_CHECKSUMS_USE_IMPORT_EXPORT",
        "AWS_COMMON_USE_IMPORT_EXPORT",
        "ENABLED_REQUEST_COMPRESSION",
        "ENABLED_ZLIB_REQUEST_COMPRESSION",
        "ENABLE_CURL_CLIENT",
        "ENFORCE_TLS_V1_2",
        "HAVE_SYSCONF",
        "INTEL_NO_ITTNOTIFY_API",
        "PLATFORM_LINUX",
        "aws_checksums_EXPORTS",
    ],
    CCFLAGS=[
        "-Wno-error",
        "-Wstrict-prototypes",
        "-Wextra",
        "-pedantic",
        "-Wno-long-long",
        "-std=gnu99",
        "-Wno-newline-eof",
    ] + {
        AMD64: [
            "-msse4.2",
            "-mavx512f",
            "-mvpclmulqdq",
            "-mavx512vl",
            "-mavx",
            "-mavx2",
            "-mpclmul",
        ],
        ARM64: [
            "-moutline-atomics",
            "-march=armv8-a+crc+crypto",
            "-mtune=neoverse-v1",
        ]
    }[ARCH],
)
