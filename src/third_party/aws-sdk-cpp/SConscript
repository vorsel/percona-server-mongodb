Import("env")

env = env.Clone()

AMD64 = 'x86_64'
ARM64 = 'aarch64'
ARCH = env['TARGET_ARCH']

if env['TARGET_OS'] != 'linux':
    env.FatalError(f"Unsupported OS: `{env['TARGET_OS']}`")
if ARCH not in (AMD64, ARM64):
    env.FatalError(f"Unsupported CPU architecture: `{ARCH}`")
env.Append(CPPPATH=[
    f"platform/linux_{ARCH}/crt/aws-crt-cpp/crt/aws-c-common/generated/include",
    f"platform/linux_{ARCH}/crt/aws-crt-cpp/generated/include"
])


envAwsCJson = env.Clone()
envAwsCJson.Append(CPPPATH=["dist/crt/aws-crt-cpp/crt/aws-c-common/source/external"])
envAwsCJson.Library(
    target="aws-cjson",
    source=[
        "dist/crt/aws-crt-cpp/crt/aws-c-common/source/external/cJSON.c"
    ])


envAwsCCommon = env.Clone()
envAwsCCommon.Append(
    CPPPATH=[
        "dist/crt/aws-crt-cpp/crt/aws-c-common/include",
        "dist/crt/aws-crt-cpp/crt/aws-c-common/source/external/libcbor",
    ],
    CPPDEFINES=[
        "AWS_AFFINITY_METHOD=AWS_AFFINITY_METHOD_PTHREAD_ATTR",
        "AWS_COMMON_EXPORTS",
        "AWS_COMMON_USE_IMPORT_EXPORT",
        "AWS_PTHREAD_GETNAME_TAKES_3ARGS",
        "AWS_PTHREAD_SETNAME_TAKES_2ARGS",
        "CJSON_HIDE_SYMBOLS",
        "ENABLED_REQUEST_COMPRESSION",
        "ENABLED_ZLIB_REQUEST_COMPRESSION",
        "ENABLE_CURL_CLIENT",
        "ENFORCE_TLS_V1_2",
        "HAVE_SYSCONF",
        "INTEL_NO_ITTNOTIFY_API",
        "PLATFORM_LINUX",
        "_POSIX_C_SOURCE=200809L",
        "_XOPEN_SOURCE=500",
        "aws_c_common_EXPORTS",
    ] + (["USE_SIMD_ENCODING"] if ARCH == AMD64 else []),
    CCFLAGS=[
        "-Wno-error",
        "-Wno-sign-compare",
        "-Wno-implicit-fallthrough",
        "-Wstrict-prototypes",
        "-pedantic",
        "-Wno-long-long",
        "-std=gnu99",
        "-Wp,-w",
    ] + {
        AMD64: [
            "-mavx",
            "-mavx2",
        ],
        ARM64: [
            "-moutline-atomics",
        ]
    }[ARCH],
    CXXFLAGS=[
        "-Wno-newline-eof",
        "-Wno-macro-redefined",
    ],
    LINKFLAGS=[
        "-lpthread",
        "-ldl",
        "-lm",
        "-lrt",
    ],
)
