envAwsS2n = env.Clone()
envAwsS2n.Append(
    CPPPATH=[
        "dist/crt/aws-crt-cpp/crt/s2n",
        "dist/crt/aws-crt-cpp/crt/s2n/api",
    ],
    CPPDEFINES=[
        "ENABLED_REQUEST_COMPRESSION",
        "ENABLED_ZLIB_REQUEST_COMPRESSION",
        "ENABLE_CURL_CLIENT",
        "ENFORCE_TLS_V1_2",
        "PLATFORM_LINUX",
